# Copy file nay thanh `.env` va dien gia tri cho may dang chay.
# `.env` da nam trong .gitignore, khong commit len repo.

# Ten SQL Server instance. Vi du:
#   .\SQLEXPRESS         -> SQL Express local default
#   TENMAY\INSTANCE      -> named instance tren may khac
#   TENMAY               -> default instance tren may khac
HANGING_SQL_SERVER=.\SQLEXPRESS

# Database RIENG cua app (chua schema `app.*`).
# Migration runner tu CREATE DATABASE neu chua co.
HANGING_APP_DB=hanging_app

# Database NGUON cua he MES chuyen treo (chi doc, KHONG sua).
# App query data MES qua 3-part name `{MES_DB}.dbo.tXxx`.
HANGING_MES_DB=MSD

# ODBC driver da cai san. Kiem tra bang:
#   Get-OdbcDriver | Where-Object Name -like "ODBC Driver*SQL Server*"
HANGING_SQL_DRIVER=ODBC Driver 17 for SQL Server

# Legacy alias (cu): neu chi set HANGING_SQL_DB ma khong set HANGING_APP_DB
# thi gia tri nay duoc dung lam APP_DB. Co the bo nguyen luon.
# HANGING_SQL_DB=hanging_app
